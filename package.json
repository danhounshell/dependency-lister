{
  "name": "dependency-lister",
  "version": "0.0.1",
  "description": "list dependencies for all repos for organizations",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "c8 --reporter=text --reporter=lcov mocha \"spec/**/*.spec.js\""
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@octokit/rest": "^18.0.0",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "c8": "^10.1.2",
    "chai": "^4.5.0",
    "mocha": "^10.8.2",
    "proxyquire": "^2.1.3",
    "sinon": "^19.0.2"
  },
  "c8": {
    "all": true,
    "include": [
      "index.js",
      "config.js",
      "configs/config.default.js",
      "services/**/*.js"
    ],
    "exclude": [
      "spec/**"
    ]
  }
}
