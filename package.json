{
  "name": "dependency-lister",
  "version": "0.0.1",
  "description": "list dependencies for all repos for organizations",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "start": "node index.js",
    "test": "npm run lint && npm run test:unit",
    "test:unit": "c8 --reporter=text --reporter=lcov mocha \"spec/**/*.spec.js\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@octokit/rest": "^18.0.0",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "c8": "^10.1.2",
    "chai": "^4.5.0",
    "eslint": "^9.22.0",
    "@eslint/js": "^9.22.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "mocha": "^10.8.2",
    "prettier": "^3.5.3",
    "proxyquire": "^2.1.3",
    "sinon": "^19.0.2"
  },
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "c8": {
    "all": true,
    "include": [
      "index.js",
      "config.js",
      "configs/config.default.js",
      "services/**/*.js"
    ],
    "exclude": [
      "spec/**"
    ]
  }
}
